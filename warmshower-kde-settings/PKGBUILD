pkgname=warmshower-kde-settings
pkgdesc='WarmShower OS KDE settings'
pkgver=4.9
pkgrel=1
arch=('any')
url="https://github.com/Warm-shower/$pkgname"
license=(GPL-1.0-only)
depends=('ttf-fantasque-nerd'
    'noto-fonts'
    'ttf-fira-sans'
    'capitaine-cursors'
    'warmshower-alacritty-config'
)
makedepends=('coreutils')
install="$pkgname.install"
provides=('warmshower-desktop-settings')
conflicts=('warmshower-desktop-settings')
source=("$pkgname-$pkgver.tar.gz::https://github.com/Warm-shower/$pkgname/archive/$pkgver.tar.gz")
sha512sums=('SKIP')

package() {
    install -d "$pkgdir/etc"
    cp -rf "$pkgname-$pkgver/etc" "$pkgdir"
    install -d "$pkgdir/usr"
    cp -rf "$pkgname-$pkgver/usr" "$pkgdir"
}
