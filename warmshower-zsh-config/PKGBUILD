# Maintainer: WarmShower OS <admin@warmshower.ai>
# Upstream-Maintainer: Vladislav Nepogodin (vnepogodin) <upstream-maintainer>

pkgname=warmshower-zsh-config
pkgver=1.0.3
pkgrel=1
pkgdesc="Zsh configuration for WarmShower OS"
arch=(any)
url="https://github.com/Warm-shower/$pkgname"
license=(GPL-1.0-only)
depends=(
  fzf
  oh-my-zsh-git
  pkgfile
  powerline-fonts
  vim
  zsh
  zsh-autosuggestions
  zsh-completions
  zsh-history-substring-search
  zsh-syntax-highlighting
  zsh-theme-powerlevel10k
)
makedepends=(
  git
)
source=("git+${url}.git#tag=v${pkgver}")
sha256sums=('SKIP')
# Note: validpgpkeys removed — source is now Warm-shower/warmshower-zsh-config fork.
# Tags are created by WarmShower OS maintainers, not upstream CachyOS developers.

package() {
    cd $srcdir/$pkgname
    install -D -m644 warmshower-config.zsh $pkgdir/usr/share/warmshower-zsh-config/warmshower-config.zsh
    install -D -m644 zshrc $pkgdir/etc/skel/.zshrc
}
