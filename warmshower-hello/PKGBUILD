# Maintainer: WarmShower OS <admin@warmshower.ai>
# Upstream-Maintainer: Vladislav Nepogodin <upstream-maintainer>

pkgname=warmshower-hello
_pkgname=Warmshower-Welcome
pkgver=0.25.0
pkgrel=1
pkgdesc='Welcome screen for WarmShower OS'
arch=('x86_64')
groups=('warmshower')
license=(GPL-3.0-or-later)
url="https://github.com/Warm-shower/Warmshower-Welcome"
depends=(
  glib2
  gtk3
  pciutils
  procps-ng
  libusb libusb-1.0.so
)
makedepends=(
  cargo
  clang
  git
  lld
  llvm
  meson
)
# TODO (WS-026): Create v0.25.0 tag in Warm-shower/Warmshower-Welcome fork, then restore #tag=v${pkgver}
source=("${pkgname}::git+$url.git")
sha512sums=('SKIP')
# Note: validpgpkeys removed — source is now Warm-shower/Warmshower-Welcome fork.

build() {
  cd "${srcdir}/${pkgname}"

  # Compile with clang
  export AR=llvm-ar
  export CC=clang
  export CXX=clang++
  export NM=llvm-nm
  export RANLIB=llvm-ranlib

  export RUSTFLAGS="-Cembed-bitcode -C opt-level=3 -Ccodegen-units=1 -Clinker=clang -C link-arg=-flto -Clink-arg=-fuse-ld=/usr/bin/ld.lld"

  meson setup --buildtype=release --prefix=/usr build
  meson compile -C build
}

package() {
  cd "${srcdir}/${pkgname}"/build

  # Compile with clang
  export AR=llvm-ar
  export CC=clang
  export CXX=clang++
  export NM=llvm-nm
  export RANLIB=llvm-ranlib

  export RUSTFLAGS="-Cembed-bitcode -C opt-level=3 -Ccodegen-units=1 -Clinker=clang -C link-arg=-flto -Clink-arg=-fuse-ld=/usr/bin/ld.lld"
  DESTDIR="${pkgdir}" meson install

  install -Dvm644 ../$pkgname.desktop \
    "$pkgdir/etc/skel/.config/autostart/$pkgname.desktop"
}

# vim:set sw=2 sts=2 et:
