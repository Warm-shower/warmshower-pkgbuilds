# Maintainer: WarmShower OS <admin@warmshower.ai>
# Upstream-Maintainer: SoulHarsh007 <admin@soulharsh007.dev>

pkgname=warmshower-plymouth-theme
pkgver=1
pkgrel=1
groups=("warmshower")
arch=("any")
url="https://github.com/Warm-shower/${pkgname}"
license=("GPL")
pkgdesc="WarmShower OS Plymouth theme"
depends=("plymouth")
makedepends=('git')
optdepends=("plymouth-kcm: for KDE settings integration")
source=("${pkgname}::git+${url}.git")
sha256sums=("SKIP")

package() {
  install -d "$pkgdir/usr/share/plymouth/themes"
  cp -rf "${srcdir}/${pkgname}/src" "${pkgdir}/usr/share/plymouth/themes/warmshower"
  install -Dm644 "${srcdir}/${pkgname}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
